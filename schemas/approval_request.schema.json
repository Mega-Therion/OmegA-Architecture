{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ApprovalRequest",
  "description": "A request for human approval of a governed action.",
  "type": "object",
  "required": ["request_id", "run_id", "action", "action_class", "risk_score", "status", "created_at"],
  "properties": {
    "request_id": { "type": "string", "format": "uuid" },
    "run_id": { "type": "string" },
    "task_id": { "type": ["string", "null"] },
    "action_envelope_id": { "type": "string" },
    "action": { "type": "string" },
    "action_class": { "type": "string", "enum": ["read", "write", "execute", "delete", "network", "auth"] },
    "risk_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "context": { "type": "object" },
    "status": { "type": "string", "enum": ["approved", "denied", "pending", "auto"] },
    "created_at": { "type": "number" },
    "expires_at": { "type": ["number", "null"] }
  }
}
