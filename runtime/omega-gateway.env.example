# OmegA Rust Gateway config (systemd EnvironmentFile format)
#
# Copy to: /etc/omega/omega-gateway.env
# Then: sudo systemctl daemon-reload && sudo systemctl restart omega-gateway

# Network
OMEGA_PORT=8787
OMEGA_TIMEOUT_SECS=30
OMEGA_RUNTIME_PROFILE=smoke-test

# Auth (recommended: set a long random token)
OMEGA_API_BEARER_TOKEN=

# Memory backend (Supabase Postgres)
# Must start with postgres:// or postgresql:// to enable PgMemoryStore.
OMEGA_DB_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
OMEGA_ENABLE_TIERED_MEMORY=false
# Tiered memory URLs (optional; when empty, s1 falls back to OMEGA_DB_URL)
OMEGA_MEMORY_S1_URL=
OMEGA_MEMORY_S2_URL=
OMEGA_MEMORY_S3_URL=
OMEGA_MEMORY_N1_URL=
OMEGA_MEMORY_N2_URL=
OMEGA_MEMORY_REINFORCE_ENABLED=false
OMEGA_MEMORY_REINFORCE_DELTA=0.05
OMEGA_MEMORY_REINFORCE_MAX=1.0
OMEGA_MEMORY_TIER_S2_THRESHOLD=0.6
OMEGA_MEMORY_TIER_S3_THRESHOLD=0.75
OMEGA_MEMORY_TIER_N1_THRESHOLD=0.9
OMEGA_MEMORY_TIER_N2_THRESHOLD=0.97

# Providers (set at least one; empty strings are allowed but limit capability)
OMEGA_GEMINI_API_KEY=
OMEGA_ANTHROPIC_API_KEY=
OMEGA_PERPLEXITY_API_KEY=
OMEGA_DEEPSEEK_API_KEY=
OMEGA_XAI_API_KEY=
OMEGA_OPENAI_API_KEY=

# Optional overrides
OMEGA_LOCAL_BASE_URL=http://127.0.0.1:11434/v1
OMEGA_LOCAL_MODEL=llama3.2:3b
OMEGA_CLI_HOME_DIR=/home/mega
OMEGA_CLI_TIMEOUT_SECS=120
OMEGA_CODEX_CLI_PATH=/home/mega/.nvm/versions/node/v22.22.0/bin/codex
OMEGA_CODEX_CLI_MODEL=gpt-5.1-codex-mini
OMEGA_CLAUDE_CLI_PATH=/home/mega/.local/bin/claude
OMEGA_CLAUDE_CLI_MODEL=claude-3-5-haiku-20241022
OMEGA_GEMINI_CLI_PATH=/home/mega/.nvm/versions/node/v22.22.0/bin/gemini
OMEGA_GEMINI_CLI_MODEL=gemini-2.5-flash-lite
OMEGA_GEMINI_MODEL=gemini-2.5-flash-lite
OMEGA_ANTHROPIC_MODEL=claude-3-5-haiku-20241022
OMEGA_MODEL=gpt-4o-mini
OMEGA_ENABLE_BACKGROUND_TASKS=false
OMEGA_ENABLE_FEDERATED_MEMORY=false
OMEGA_HEADLESS=false
OMEGA_SYSTEM_PROMPT_PATH=/var/lib/omega/SYSTEM_PROMPT.md
